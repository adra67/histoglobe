    </div>

    <!-- Modal Connexion -->
    <div class="modal" id="authModal">
        <div class="modal-content">
            <h2 style="margin-bottom:20px;">Connexion / Inscription</h2>
            <div style="display:flex; gap:10px; margin-bottom:20px;">
                <button class="tab-btn active" onclick="switchTab('login')" style="flex:1; padding:10px; background:#f39c12; border:none; color:white;">Connexion</button>
                <button class="tab-btn" onclick="switchTab('register')" style="flex:1; padding:10px; background:rgba(255,255,255,0.1); border:none; color:white;">Inscription</button>
            </div>
            <div id="loginTab">
                <form id="loginForm">
                    <div class="form-group"><label>Email</label><input type="email" id="loginEmail" required></div>
                    <div class="form-group"><label>Mot de passe</label><input type="password" id="loginPassword" required></div>
                    <button type="submit" class="btn">Se connecter</button>
                </form>
                <div id="loginMessage" class="message"></div>
            </div>
            <div id="registerTab" style="display:none;">
                <form id="registerForm">
                    <div class="form-group"><label>Pseudo</label><input type="text" id="regUsername" required></div>
                    <div class="form-group"><label>Email</label><input type="email" id="regEmail" required></div>
                    <div class="form-group"><label>Mot de passe</label><input type="password" id="regPassword" required></div>
                    <button type="submit" class="btn">S'inscrire</button>
                </form>
                <div id="registerMessage" class="message"></div>
            </div>
            <button onclick="closeModal()" style="margin-top:20px; background:none; border:none; color:#f39c12; cursor:pointer;">Fermer</button>
        </div>
    </div>

    <!-- Modal Admin -->
    <div class="modal" id="adminModal">
        <div class="modal-content" style="max-width: 900px; max-height: 80vh; overflow-y: auto;">
            <h2 style="margin-bottom:20px;">🔐 Panneau Administrateur</h2>
            <div id="adminContent"></div>
            <button onclick="closeAdminModal()" style="margin-top:20px; background:#f39c12; border:none; padding:10px; border-radius:5px; cursor:pointer;">Fermer</button>
        </div>
    </div>

