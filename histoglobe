            <option value="Afrique">🌍 Afrique</option>
            <option value="Amérique">🌎 Amériques</option>
            <option value="Asie">🌏 Asie</option>
            <option value="Europe">🌍 Europe</option>
        </select>
        <select id="countrySelect" onchange="filterPlaces()">
            <option value="">🏛️ Tous pays</option>
        </select>
        <input type="text" id="searchInput" placeholder="Rechercher..." onkeyup="filterPlaces()">
        <button onclick="resetFilters()">⟳ Réinitialiser</button>
        <button id="adminBtn" style="background:#e74c3c;" onclick="openAdminPanel()">🔐 Admin</button>
    </div>

    <div class="side-panel" id="sidePanel">
        <div class="panel-header">
